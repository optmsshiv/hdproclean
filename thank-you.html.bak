<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thank You — HD Pro Cleaning</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="assets/icons/favicon.ico" type="image/x-icon" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <style>
    /* ── Tokens ── */
    :root {
      --teal:     #01c3cc;
      --teal-dk:  #009ea6;
      --teal-lt:  #e0fafb;
      --dark:     #0d1b1e;
      --mid:      #1e3136;
      --txt:      #cbd5d7;
      --white:    #ffffff;
      --radius:   18px;
      --transition: 0.35s cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      font-family: 'Georgia', 'Times New Roman', serif;
      background: var(--dark);
      color: var(--txt);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* ── Animated background bubbles ── */
    .bg-bubbles {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
    }
    .bubble {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, rgba(1,195,204,.18), rgba(1,195,204,.04));
      animation: float linear infinite;
    }
    .bubble:nth-child(1)  { width:320px; height:320px; left:-80px;  bottom:-80px;  animation-duration:18s; }
    .bubble:nth-child(2)  { width:180px; height:180px; right:5%;   top:10%;       animation-duration:13s; animation-delay:-4s; }
    .bubble:nth-child(3)  { width:260px; height:260px; right:-60px; bottom:20%;    animation-duration:21s; animation-delay:-8s; }
    .bubble:nth-child(4)  { width:100px; height:100px; left:20%;   top:5%;        animation-duration:9s;  animation-delay:-2s; }
    @keyframes float {
      0%   { transform: translateY(0) scale(1); opacity:.7; }
      50%  { transform: translateY(-30px) scale(1.05); opacity:1; }
      100% { transform: translateY(0) scale(1); opacity:.7; }
    }

    /* ── Card ── */
    .card {
      position: relative;
      z-index: 1;
      background: var(--mid);
      border: 1px solid rgba(1,195,204,.2);
      border-radius: var(--radius);
      padding: 56px 48px 48px;
      max-width: 540px;
      width: 90%;
      text-align: center;
      box-shadow: 0 32px 80px rgba(0,0,0,.5), 0 0 0 1px rgba(1,195,204,.07);
      animation: rise .7s cubic-bezier(.4,0,.2,1) both;
    }
    @keyframes rise {
      from { opacity:0; transform: translateY(40px) scale(.97); }
      to   { opacity:1; transform: translateY(0)    scale(1);   }
    }

    /* ── Checkmark circle ── */
    .check-wrap {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal), var(--teal-dk));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 32px;
      box-shadow: 0 0 0 12px rgba(1,195,204,.12), 0 8px 30px rgba(1,195,204,.3);
      animation: pop .6s .4s cubic-bezier(.175,.885,.32,1.275) both;
    }
    @keyframes pop {
      from { transform: scale(0); opacity:0; }
      to   { transform: scale(1); opacity:1; }
    }
    .check-wrap svg {
      width: 46px;
      height: 46px;
      stroke: var(--white);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
    }
    .check-wrap svg path {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: draw-check .5s .9s ease forwards;
    }
    @keyframes draw-check {
      to { stroke-dashoffset: 0; }
    }

    /* ── Text ── */
    .tag {
      display: inline-block;
      font-family: 'Courier New', monospace;
      font-size: .7rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--teal);
      background: rgba(1,195,204,.1);
      border: 1px solid rgba(1,195,204,.25);
      border-radius: 4px;
      padding: 3px 10px;
      margin-bottom: 16px;
      animation: fade-in .5s .6s both;
    }

    h1 {
      font-size: clamp(1.7rem, 5vw, 2.3rem);
      font-weight: 700;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 14px;
      animation: fade-in .5s .7s both;
    }
    h1 span { color: var(--teal); }

    .sub {
      font-size: 1rem;
      line-height: 1.7;
      color: #8ea8ac;
      margin-bottom: 36px;
      animation: fade-in .5s .8s both;
    }

    @keyframes fade-in {
      from { opacity:0; transform: translateY(12px); }
      to   { opacity:1; transform: translateY(0); }
    }

    /* ── Info boxes ── */
    .info-row {
      display: flex;
      gap: 12px;
      margin-bottom: 36px;
      animation: fade-in .5s .9s both;
    }
    .info-box {
      flex: 1;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 12px;
      padding: 16px 12px;
      font-size: .85rem;
      color: #8ea8ac;
      line-height: 1.5;
    }
    .info-box i {
      display: block;
      font-size: 1.2rem;
      color: var(--teal);
      margin-bottom: 6px;
    }
    .info-box strong {
      display: block;
      color: var(--white);
      font-size: .8rem;
      margin-bottom: 2px;
    }

    /* ── Buttons ── */
    .btn-group {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      animation: fade-in .5s 1s both;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 26px;
      border-radius: 10px;
      font-size: .9rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: var(--transition);
      border: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--teal), var(--teal-dk));
      color: var(--white);
      box-shadow: 0 6px 20px rgba(1,195,204,.3);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(1,195,204,.45);
    }
    .btn-ghost {
      background: transparent;
      color: var(--teal);
      border: 1px solid rgba(1,195,204,.35);
    }
    .btn-ghost:hover {
      background: rgba(1,195,204,.08);
      transform: translateY(-2px);
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(1,195,204,.2), transparent);
      margin: 36px 0 24px;
      animation: fade-in .5s .95s both;
    }

    /* ── Logo strip ── */
    .logo-strip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: .8rem;
      color: #5c7a7e;
      animation: fade-in .5s 1.05s both;
    }
    .logo-strip img {
      height: 28px;
      opacity: .7;
    }

    /* ── Countdown ── */
    #countdown {
      font-size: .75rem;
      color: #5c7a7e;
      margin-top: 14px;
      animation: fade-in .5s 1.1s both;
    }
    #countdown span { color: var(--teal); font-weight: 700; }

    @media (max-width: 480px) {
      .card { padding: 40px 24px 36px; }
      .info-row { flex-direction: column; }
    }
  </style>
</head>
<body>

  <!-- Animated background -->
  <div class="bg-bubbles">
    <div class="bubble"></div>
    <div class="bubble"></div>
    <div class="bubble"></div>
    <div class="bubble"></div>
  </div>

  <!-- Main card -->
  <div class="card">

    <!-- Animated checkmark -->
    <div class="check-wrap">
      <svg viewBox="0 0 52 52">
        <path d="M14 27 L22 35 L38 18" />
      </svg>
    </div>

    <div class="tag"><i class="fa-solid fa-circle-check"></i>&nbsp; Submitted</div>

    <h1>Thank You for<br><span>Reaching Out!</span></h1>

    <p class="sub">
      We've received your request and our team will get back to you shortly.<br>
      Expect a call or email within <strong style="color:var(--white)">24 hours</strong>.
    </p>

    <!-- Quick-info boxes -->
    <div class="info-row">
      <div class="info-box">
        <i class="fa-solid fa-phone"></i>
        <strong>Call Us Directly</strong>
        +1 718-360-0226
      </div>
      <div class="info-box">
        <i class="fa-solid fa-envelope"></i>
        <strong>Email Us</strong>
        info@hdproclean.us
      </div>
      <div class="info-box">
        <i class="fa-solid fa-clock"></i>
        <strong>Working Hours</strong>
        Mon–Sun 9 AM–5 PM
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="btn-group">
      <a href="/" class="btn btn-primary">
        <i class="fa-solid fa-house"></i> Back to Home
      </a>
      <a href="tel:+17183600226" class="btn btn-ghost">
        <i class="fa-solid fa-phone"></i> Call Now
      </a>
    </div>

    <div class="divider"></div>

    <!-- Branding -->
    <div class="logo-strip">
      <img src="assets/logo/main_logo.png" alt="HD Pro Cleaning Logo" onerror="this.style.display='none'">
      <span>HD Pro Cleaning — Professional Cleaning Services</span>
    </div>

    <p id="countdown">Redirecting to home in <span id="timer">10</span>s…</p>
  </div>

  <script>
    // Read URL param to personalize heading
    const params = new URLSearchParams(location.search);
    const type = params.get('type'); // 'booking' | 'contact'
    if (type === 'booking') {
      document.querySelector('h1').innerHTML = 'Booking<br><span>Confirmed!</span>';
    } else if (type === 'contact') {
      document.querySelector('h1').innerHTML = 'Message<br><span>Received!</span>';
    }

    // Countdown redirect
    let secs = 10;
    const timerEl = document.getElementById('timer');
    const interval = setInterval(() => {
      secs--;
      timerEl.textContent = secs;
      if (secs <= 0) { clearInterval(interval); location.href = '/'; }
    }, 1000);
  </script>

</body>
</html>
